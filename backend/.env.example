# ── Simulation ──────────────────────────────────
MODEL_TYPE=fire_sense_net    # "fire_sense_net" or "unet"
MODEL_PATH=models/unet_checkpoint.pt
FIRE_SENSE_NET_PATH=models/firesense_best.pth
DEVICE=cpu
GRID_SIZE=64

# ── Weather (Open-Meteo — free, no key needed) ──
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
DEFAULT_LAT=39.8283
DEFAULT_LON=-98.5795

# ── LLM Assistant ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Options: qwen2.5:1.5b, llama3.2, or an OpenAI model name
OLLAMA_MODEL=qwen2.5:1.5b

# RECOMMENDED: Get at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional Data APIs ──────────────────────────
# RECOMMENDED: Get at https://firms.modaps.eosdis.nasa.gov/ (free)
FIRMS_API_KEY=