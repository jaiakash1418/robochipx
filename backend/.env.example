# FastAPI
APP_NAME=Wildfire Spread Predictor
APP_VERSION=1.0.0
DEBUG=true

# Model
MODEL_PATH=models/unet_checkpoint.pt
DEVICE=cpu
INPUT_CHANNELS=12

# Grid
GRID_SIZE=64
CELL_SIZE_METERS=500

# Weather (Open-Meteo default lat/lon - center of US)
DEFAULT_LAT=39.8283
DEFAULT_LON=-98.5795

# Ollama (optional - used first if available)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# OpenAI (optional fallback - leave blank to skip)
OPENAI_API_KEY=
