# FastAPI
APP_NAME=Wildfire Spread Predictor
APP_VERSION=1.0.0
DEBUG=true

# Model
MODEL_PATH=models/unet_checkpoint.pt
DEVICE=cpu
INPUT_CHANNELS=12

# Grid
GRID_SIZE=64
CELL_SIZE_METERS=500

# Weather (Open-Meteo default lat/lon - center of US)
DEFAULT_LAT=39.8283
DEFAULT_LON=-98.5795

# LLM (optional - leave blank to use fallback responses)
OPENAI_API_KEY=
